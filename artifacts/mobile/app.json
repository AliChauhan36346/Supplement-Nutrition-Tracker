{
  "expo": {
    "name": "Supplement Tracker Pro",
    "slug": "supplement-tracker-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "suptracker",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#F7FBF8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vitaroutine.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Supplement Tracker to access your camera to scan supplement barcodes.",
        "NSUserNotificationsUsageDescription": "Allow Supplement Tracker to send reminders when it is time to take your supplements."
      }
    },
    "android": {
      "package": "com.vitaroutine.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#F7FBF8"
      },
      "permissions": [
        "CAMERA",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "SCHEDULE_EXACT_ALARM",
        "BILLING",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "themeColor": "#10B981",
      "description": "Track your vitamins, supplements, and medications daily. Build healthy streaks, view your history, and stay consistent — all in one app.",
      "lang": "en"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Supplement Tracker to access your camera to scan supplement barcodes."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#10B981",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "43bc5a4b-e641-45d6-b5fb-af8c68fe7614"
      }
    },
    "owner": "aliabbas346"
  }
}
