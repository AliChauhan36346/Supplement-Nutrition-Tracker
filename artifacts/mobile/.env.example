# RevenueCat — Google Play (Android) public SDK key
# Dashboard → Project → Apps → Google Play app → Public API key (starts with goog_)
EXPO_PUBLIC_REVENUECAT_GOOGLE_API_KEY=goog_REPLACE_ME

# Optional fallback used if platform-specific key is missing
# EXPO_PUBLIC_REVENUECAT_API_KEY=goog_REPLACE_ME

# Optional later (iOS)
# EXPO_PUBLIC_REVENUECAT_APPLE_API_KEY=appl_REPLACE_ME

# Cloud sync API (optional)
# EXPO_PUBLIC_API_URL=http://10.0.0.1:5000
